  "androidcodeinjection":"<YYAndroidStringValuesInjection>\r\n<string name=\"gps_app_id\">${YYEXTOPT_GMGooglePlayServices_AppID}</string>\r\n</YYAndroidStringValuesInjection>\r\n\r\n<YYAndroidGradleDependencies>\r\nandroid {\r\n    lintOptions {\r\n        checkReleaseBuilds false\r\n        abortOnError false\r\n    }\r\n}\r\n\r\n//https://developers.google.com/android/guides/setup\r\ndependencies {\r\n//https://developers.google.com/android/guides/releases\r\n    //Always latest verion\r\n    //implementation \"com.google.android.gms:play-services-games-v2:+\"\r\n   //This seems to be a stable version\r\n   implementation \"com.google.android.gms:play-services-games-v2:20.1.2\"\r\n}\r\n\r\n</YYAndroidGradleDependencies>\r\n\r\n<YYAndroidManifestApplicationInject>\r\n\r\n<!-- https://developers.google.com/games/services/android/quickstart -->\r\n\r\n<meta-data android:name=\"com.google.android.gms.version\" android:value=\"@integer/google_play_services_version\"/>\r\n<meta-data android:name=\"com.google.android.gms.games.APP_ID\" android:value=\"@string/gps_app_id\"/>\r\n<meta-data android:name=\"com.google.android.gms.appstate.APP_ID\" android:value=\"@string/gps_app_id\"/>\r\n\r\n</YYAndroidManifestApplicationInject>\r\n\r\n<YYAndroidProguard>\r\n<![CDATA[\r\n# AIDL licensing stubs used by Play Store\r\n-keep public class com.google.vending.licensing.ILicensingService   { void <init>(); }\r\n-keep public class com.android.vending.licensing.ILicensingService  { void <init>(); }\r\n-keep public class com.google.android.vending.licensing.ILicensingService { void <init>(); }\r\n\r\n# Support / AndroidX @Keep annotations\r\n-keep class android.support.annotation.Keep                { void <init>(); }\r\n-keep @interface android.support.annotation.Keep           { void <init>(); }\r\n-keep class androidx.annotation.Keep                       { void <init>(); }\r\n-keep @interface androidx.annotation.Keep                  { void <init>(); }\r\n\r\n# GMS “keep-name” / ReflectedParcelable markers\r\n-keep class com.google.android.gms.common.internal.ReflectedParcelable { void <init>(); }\r\n-keep,allowshrinking class * implements com.google.android.gms.common.internal.ReflectedParcelable { void <init>(); }\r\n\r\n-keep @interface com.google.android.gms.common.annotation.KeepName    { void <init>(); }\r\n-keep,allowshrinking @com.google.android.gms.common.annotation.KeepName class * { void <init>(); }\r\n\r\n# Dynamite (split-module) marker\r\n-keep @interface com.google.android.gms.common.util.DynamiteApi       { void <init>(); }\r\n\r\n# AndroidX start-up / lifecycle helpers referenced via ServiceLoader\r\n-keep,includedescriptorclasses class * extends androidx.startup.Initializer { void <init>(); }\r\n-keep !interface * implements androidx.lifecycle.LifecycleObserver         { void <init>(); }\r\n\r\n# VersionedParcelable framework\r\n-keep class * implements androidx.versionedparcelable.VersionedParcelable   { void <init>(); }\r\n-keep public class androidx.versionedparcelable.ParcelImpl                  { void <init>(); }\r\n]]>\r\n</YYAndroidProguard>",
